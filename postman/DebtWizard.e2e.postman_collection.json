    {
      "name": "Step 21 - Delete Saved Plan",
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('[DeleteSavedPlan] Status 200', () => pm.response.to.have.status(200));",
        "pm.test('[DeleteSavedPlan] Success', () => pm.expect(pm.response.json().message).to.eql('Success'));"
      ]}}],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/planning/saved", "host": ["{{baseUrl}}"], "path": ["api","planning","saved"] }
